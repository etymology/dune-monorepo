{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "dune-tension (debug spoofed)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_tension.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "SPOOF_AUDIO": "1",
                "SPOOF_PLC": "1",
                "SPOOF_SERVO": "1",
                "SPOOF_VALVE": "1"
            },
            "justMyCode": false
        },
        {
            "name": "dune-tension (real desktop mode)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_tension.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PLC_IO_MODE": "desktop",
                "DESKTOP_SERVER_URL": "http://192.168.137.1:8080"
            },
            "justMyCode": false
        },
        {
            "name": "dune-tension (real direct PLC)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_tension.main",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PLC_IO_MODE": "direct",
                "PLC_IP_ADDRESS": "192.168.140.13"
            }
        },
        {
            "name": "PLC RLL syntax",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/dune_winder/tools/vscode-plc-rll"
            ]
        },
        {
            "name": "dune-winder (simulated PLC)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "PLC_MODE=SIM",
                "LOG=TRUE",
                "LOG_IO=FALSE",
                "START=FALSE"
            ]
        },
        {
            "name": "dune-winder",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "redirectOutput": true
        },
        {
            "name": "dune-winder (integrated terminal)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
