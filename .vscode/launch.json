{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Tensiometer with SPOOF_AUDIO",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_tension.main",
            "cwd": "${workspaceFolder}/dune_tension",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dune_tension/src",
                "SPOOF_AUDIO": "1",
                "SPOOF_SERVO": "1"
            }
        },
        {
            "name": "PLC RLL syntax",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/dune_winder/tools/vscode-plc-rll"
            ]
        },
        {
            "name": "dune-winder (simulated PLC)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}/dune_winder",
            "console": "integratedTerminal",
            "args": [
                "PLC_MODE=SIM",
                "LOG=TRUE",
                "LOG_IO=FALSE",
                "START=FALSE"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dune_winder/src"
            }
        },
        {
            "name": "dune-winder",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}/dune_winder",
            "console": "internalConsole",
            "redirectOutput": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dune_winder/src"
            }
        },
        {
            "name": "dune-winder (integrated terminal)",
            "type": "debugpy",
            "request": "launch",
            "module": "dune_winder",
            "cwd": "${workspaceFolder}/dune_winder",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/dune_winder/src"
            }
        }
    ]
}
