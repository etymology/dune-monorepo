XIC(INIT_DONE)CMP(STATE=1)OTE(STATE1_IND);   XIC(STATE1_IND)CMP(MOVE_TYPE=0)MOV(0,STATE_REQUEST);   XIC(STATE1_IND)CMP(MOVE_TYPE=2)MOV(3,STATE_REQUEST);   XIC(STATE1_IND)CMP(MOVE_TYPE=4)MOV(5,STATE_REQUEST);   XIC(STATE1_IND)CMP(MOVE_TYPE=5)MOV(6,STATE_REQUEST);   XIC(STATE1_IND)CMP(MOVE_TYPE=8)MOV(9,STATE_REQUEST);   XIC(STATE1_IND)CMP(STATE_REQUEST<>0)OSR(null,state_request_changed);   XIC(state_request_changed)MOV(STATE_REQUEST,NEXTSTATE);   ;   